{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.byluto.homey_ping",
  "version": "1.0.5",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Homey Ping",
    "nl": "Homey Ping"
  },
  "description": {
    "en": "Monitor devices and use online/offline status in Homey Flows (ICMP with optional TCP fallback).",
    "nl": "Monitor apparaten en gebruik online/offline status in Homey Flows (ICMP met optionele TCP fallback)."
  },
  "changelog": {
    "en": "Store page update: PNG icons are now black for better contrast.",
    "nl": "Store-pagina update: PNG-iconen zijn nu zwart voor beter contrast."
  },
  "category": [
    "tools"
  ],
  "brandColor": "#1C6E8C",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "ByLuto",
    "email": "development@byluto.nl"
  },
  "support": "mailto:development@byluto.nl",
  "flow": {
    "triggers": [
      {
        "id": "became-online",
        "icon": "/assets/icon.svg",
        "title": {
          "en": "Device came online",
          "nl": "Apparaat kwam online"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=icmp_ping"
          }
        ]
      },
      {
        "id": "became-offline",
        "icon": "/assets/icon.svg",
        "title": {
          "en": "Device went offline",
          "nl": "Apparaat ging offline"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=icmp_ping"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "is-online",
        "icon": "/assets/icon.svg",
        "title": {
          "en": "Is online",
          "nl": "Is online"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=icmp_ping"
          }
        ]
      },
      {
        "id": "is-offline",
        "icon": "/assets/icon.svg",
        "title": {
          "en": "Is offline",
          "nl": "Is offline"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=icmp_ping"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "ping-now",
        "icon": "/assets/icon.svg",
        "title": {
          "en": "Ping now",
          "nl": "Ping nu"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=icmp_ping"
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Ping Device",
        "nl": "Ping apparaat"
      },
      "class": "sensor",
      "capabilities": [
        "onoff",
        "ping_status"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "pair": [
        {
          "id": "manual_add"
        }
      ],
      "settings": [
        {
          "id": "host",
          "type": "text",
          "label": {
            "en": "Host or IP",
            "nl": "Host of IP"
          },
          "hint": {
            "en": "For example: 192.168.1.10 or nas.local",
            "nl": "Bijvoorbeeld: 192.168.1.10 of nas.local"
          },
          "value": "8.8.8.8"
        },
        {
          "id": "interval",
          "type": "number",
          "label": {
            "en": "Ping interval (seconds)",
            "nl": "Ping-interval (seconden)"
          },
          "hint": {
            "en": "How often the device is pinged.",
            "nl": "Hoe vaak het apparaat wordt gepingd."
          },
          "value": 30,
          "attr": {
            "min": 5,
            "max": 3600,
            "step": 1
          }
        },
        {
          "id": "timeout",
          "type": "number",
          "label": {
            "en": "Ping timeout (ms)",
            "nl": "Ping-timeout (ms)"
          },
          "hint": {
            "en": "Maximum wait time per ping.",
            "nl": "Maximale wachttijd per ping."
          },
          "value": 2000,
          "attr": {
            "min": 500,
            "max": 10000,
            "step": 100
          }
        },
        {
          "id": "probe_mode",
          "type": "dropdown",
          "label": {
            "en": "Probe mode",
            "nl": "Controlemodus"
          },
          "hint": {
            "en": "AUTO tries ICMP first and falls back to TCP when ICMP is unavailable.",
            "nl": "AUTO probeert eerst ICMP en valt terug op TCP als ICMP niet beschikbaar is."
          },
          "value": "auto",
          "values": [
            {
              "id": "auto",
              "label": {
                "en": "Auto (ICMP -> TCP)",
                "nl": "Auto (ICMP -> TCP)"
              }
            },
            {
              "id": "icmp",
              "label": {
                "en": "ICMP only",
                "nl": "Alleen ICMP"
              }
            },
            {
              "id": "tcp",
              "label": {
                "en": "TCP only",
                "nl": "Alleen TCP"
              }
            }
          ]
        },
        {
          "id": "tcp_port",
          "type": "number",
          "label": {
            "en": "TCP fallback port",
            "nl": "TCP fallback-poort"
          },
          "hint": {
            "en": "Used for TCP mode and AUTO fallback. Example: 443, 80, 22",
            "nl": "Gebruikt voor TCP-modus en AUTO fallback. Bijvoorbeeld: 443, 80, 22"
          },
          "value": 443,
          "attr": {
            "min": 1,
            "max": 65535,
            "step": 1
          }
        }
      ],
      "capabilitiesOptions": {
        "onoff": {
          "setable": true,
          "title": {
            "en": "Ping now",
            "nl": "Ping nu"
          }
        }
      },
      "images": {
        "small": "/drivers/icmp_ping/assets/images/small.png",
        "large": "/drivers/icmp_ping/assets/images/large.png",
        "xlarge": "/drivers/icmp_ping/assets/images/xlarge.png"
      },
      "id": "icmp_ping"
    }
  ],
  "capabilities": {
    "ping_status": {
      "type": "enum",
      "title": {
        "en": "Status",
        "nl": "Status"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "values": [
        {
          "id": "online",
          "title": {
            "en": "Online",
            "nl": "Online"
          }
        },
        {
          "id": "offline",
          "title": {
            "en": "Offline",
            "nl": "Offline"
          }
        }
      ]
    }
  }
}